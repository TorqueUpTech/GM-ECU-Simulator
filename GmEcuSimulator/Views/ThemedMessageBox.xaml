<Window x:Class="GmEcuSimulator.Views.ThemedMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Message"
        SizeToContent="WidthAndHeight"
        MinWidth="380" MaxWidth="640"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Style="{StaticResource Window.Dialog}"
        Background="{DynamicResource Chrome.BgBrush}">

    <!-- Paint the whole DockPanel with the chrome surface so any layout slack
         (WindowChrome resize borders, SizeToContent rounding, the Material
         BundledTheme bleed seen elsewhere) doesn't expose the Window's
         Bg.BaseBrush underneath - that brush reads as near-black against the
         lighter chrome and produced the "black band" the user saw beneath
         the footer buttons. -->
    <DockPanel LastChildFill="True"
               Background="{DynamicResource Chrome.BgBrush}">

        <!-- Custom titlebar (matches the main shell) -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource Chrome.GradientBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ChromeTitle"
                       Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                       Style="{StaticResource Text.Body}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"/>
            <Button Grid.Column="1"
                    Style="{StaticResource Button.ChromeClose}"
                    Width="46" Height="32"
                    Click="OnCloseClicked"
                    ToolTip="Close">
                <Path Data="{StaticResource Icon.Close}"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.2"
                      Width="10" Height="10"/>
            </Button>
        </Grid>

        <!-- Footer with configurable button row -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource Chrome.BgBrush}"
                BorderBrush="{DynamicResource Border.SubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <StackPanel x:Name="ButtonRow"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"/>
        </Border>

        <!-- Body: severity glyph + message text.
             Painted with Chrome.BgBrush (same as the footer) so the body
             reads as one surface with the chrome above and below. Without
             this, the body fell back to the Window's Bg.BaseBrush which in
             most palettes is markedly darker than the chrome, producing a
             visible "black band" between the titlebar and the message. -->
        <Grid Background="{DynamicResource Chrome.BgBrush}">
        <Grid Margin="18,16,18,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="IconColumn" Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Severity indicator. A coloured disc with a single glyph letter
                 keeps things palette-driven (no rasterised system icons). The
                 host code toggles Visibility on IconColumn when severity=None. -->
            <Border x:Name="SeverityBadge"
                    Grid.Column="0"
                    Width="32" Height="32"
                    CornerRadius="16"
                    Margin="0,2,16,0"
                    VerticalAlignment="Top"
                    Background="{DynamicResource Accent.PrimaryBrush}">
                <TextBlock x:Name="SeverityGlyph"
                           Text="i"
                           Foreground="{DynamicResource Accent.OnPrimaryBrush}"
                           FontFamily="{StaticResource Font.SansDisplay}"
                           FontWeight="Bold"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="MessageBlock"
                       Grid.Column="1"
                       Style="{StaticResource Text.Body}"
                       Foreground="{DynamicResource Text.PrimaryBrush}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
        </Grid>
        </Grid>
    </DockPanel>
</Window>
