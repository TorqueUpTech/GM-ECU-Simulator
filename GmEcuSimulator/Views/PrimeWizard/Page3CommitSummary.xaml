<UserControl x:Class="GmEcuSimulator.Views.PrimeWizard.Page3CommitSummary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontSize="14">
    <UserControl.Resources>
        <Style x:Key="Caption14" TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}">
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="0,12">
            <TextBlock Text="Review what will be applied. Click Apply Prime to register the ECU, or Back to make changes."
                       Style="{StaticResource Caption14}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <Border Padding="14"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource Border.SubtleBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource Chrome.BgBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Archive:" Style="{StaticResource Caption14}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ArchiveLine}" FontFamily="Consolas" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Loaded bin (if any):" Style="{StaticResource Caption14}" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LoadedBinLine}" FontFamily="Consolas" Margin="0,6,0,0" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Security module:" Style="{StaticResource Caption14}" Margin="0,6,0,0" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              ItemsSource="{Binding AvailableSecurityModules}"
                              SelectedItem="{Binding SelectedSecurityModule, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              FontFamily="Consolas"
                              Margin="0,6,0,0"
                              HorizontalAlignment="Left"
                              MinWidth="260"/>

                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="Fixed seed (10 hex):"
                               Style="{StaticResource Caption14}"
                               Margin="0,6,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsFixedSeedVisible, Converter={StaticResource BoolToVis}}"/>
                    <StackPanel Grid.Row="3" Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="0,6,0,0"
                                Visibility="{Binding IsFixedSeedVisible, Converter={StaticResource BoolToVis}}">
                        <TextBox Text="{Binding FixedSeedHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 MinWidth="180"
                                 ToolTip="10 hex characters (5 bytes), e.g. 438930D306. Leave blank for a random seed each session."/>
                        <TextBlock Text="leave blank → random per session"
                                   Style="{StaticResource Caption14}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="Phase 3 reads" Style="{StaticResource Text.Subtitle}" Margin="0,16,0,6"/>

            <Border Padding="14"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource Border.SubtleBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource Chrome.BgBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Total reads:" Style="{StaticResource Caption14}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalRows}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="From $53 bytecode literal:" Style="{StaticResource Caption14}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BytecodeRows}" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="From bin walker:" Style="{StaticResource Caption14}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BinRows}" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="From auto-populate default:" Style="{StaticResource Caption14}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DefaultRows}" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="From user override:" Style="{StaticResource Caption14}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding UserRows}" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Empty (zero bytes):" Style="{StaticResource Caption14}" Margin="0,4,0,0"/>
                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding EmptyRows}"/>
                        <TextBlock Margin="10,0,0,0" Foreground="Red" FontWeight="Bold"
                                   Text="(includes COMPARE_DATA reads - will fail Phase 3!)"
                                   Visibility="{Binding HasEmptyCompared, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding Flags}" Margin="0,16,0,0">
                <ItemsControl.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="Consolas"/>
                        <Setter Property="Foreground" Value="DarkGoldenrod"/>
                        <Setter Property="Margin" Value="0,2"/>
                    </Style>
                </ItemsControl.Resources>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
