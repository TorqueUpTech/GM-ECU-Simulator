<UserControl x:Class="GmEcuSimulator.Views.PrimeWizard.Page1Archive"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Vertical" Margin="0,12">
        <TextBlock Text="Pick the DPS programming archive (.zip) you want the simulator to honour."
                   Style="{StaticResource Text.Caption}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <Button Content="Browse for archive..."
                HorizontalAlignment="Left"
                MinWidth="200"
                Padding="14,8"
                Command="{Binding PickArchiveCommand}"/>

        <Border Margin="0,16,0,0"
                Padding="14"
                CornerRadius="4"
                BorderBrush="{DynamicResource Border.SubtleBrush}"
                BorderThickness="1"
                Background="{DynamicResource Chrome.BgBrush}"
                Visibility="{Binding IsArchiveLoaded, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Archive:" Style="{StaticResource Text.Caption}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ArchiveBaseName}" FontFamily="Consolas"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Utility file:" Style="{StaticResource Text.Caption}" Margin="0,6,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UtilityFileName}" Margin="0,6,0,0" FontFamily="Consolas"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Calibration files:" Style="{StaticResource Text.Caption}" Margin="0,6,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CalCount}" Margin="0,6,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="OS Part Number:" Style="{StaticResource Text.Caption}" Margin="0,6,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding OsPartNumber, FallbackValue=(none)}" Margin="0,6,0,0" FontFamily="Consolas"/>
            </Grid>
        </Border>

        <Border Margin="0,16,0,0"
                Padding="14"
                CornerRadius="4"
                BorderBrush="Red"
                BorderThickness="1"
                Background="#22FF0000"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap"
                       Foreground="Red"/>
        </Border>
    </StackPanel>
</UserControl>
