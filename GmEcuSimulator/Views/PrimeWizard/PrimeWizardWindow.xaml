<Window x:Class="GmEcuSimulator.Views.PrimeWizard.PrimeWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GmEcuSimulator.ViewModels.PrimeWizard"
        xmlns:pages="clr-namespace:GmEcuSimulator.Views.PrimeWizard"
        Title="DPS Prime Wizard"
        Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontSize="14"
        Style="{StaticResource Window.Dialog}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:Page1ArchiveViewModel}">
            <pages:Page1Archive/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:Page2Phase3ViewModel}">
            <pages:Page2Phase3Review/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:Page3CommitViewModel}">
            <pages:Page3CommitSummary/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Titlebar -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource Chrome.GradientBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="DPS Prime Wizard"
                       Style="{StaticResource Text.Body}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"/>
            <Button Grid.Column="1"
                    Style="{StaticResource Button.ChromeClose}"
                    Width="46" Height="32"
                    Click="OnCloseClicked"
                    ToolTip="Close">
                <Path Data="{StaticResource Icon.Close}"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.2"
                      Width="10" Height="10"/>
            </Button>
        </Grid>

        <!-- Step header -->
        <Border DockPanel.Dock="Top" Padding="20,14,20,4">
            <TextBlock Text="{Binding StepLabel}"
                       Style="{StaticResource Text.Subtitle}"/>
        </Border>

        <!-- Footer with Back / Next / Apply / Cancel -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource Chrome.BgBrush}"
                BorderBrush="{DynamicResource Border.SubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="&lt; Back"
                        MinWidth="100" Margin="0,0,8,0"
                        Command="{Binding BackCommand}"/>

                <Button Grid.Column="2" Content="Cancel"
                        MinWidth="100" Margin="0,0,8,0"
                        IsCancel="True"
                        Command="{Binding CancelCommand}"/>

                <Button Grid.Column="3" Content="{Binding NextButtonText}"
                        MinWidth="100" Margin="0,0,8,0"
                        Visibility="{Binding IsNextVisible, Converter={StaticResource BoolToVis}}"
                        IsDefault="True"
                        Command="{Binding NextCommand}"/>

                <Button Grid.Column="4" Content="Apply Prime"
                        MinWidth="120"
                        Visibility="{Binding IsApplyVisible, Converter={StaticResource BoolToVis}}"
                        IsDefault="True"
                        Command="{Binding ApplyCommand}"/>
            </Grid>
        </Border>

        <!-- Page host -->
        <Grid Margin="20,8,20,8">
            <ContentControl Content="{Binding ArchivePage}"
                            Visibility="{Binding IsArchivePage, Converter={StaticResource BoolToVis}}"/>
            <ContentControl Content="{Binding Phase3Page}"
                            Visibility="{Binding IsPhase3Page, Converter={StaticResource BoolToVis}}"/>
            <ContentControl Content="{Binding CommitPage}"
                            Visibility="{Binding IsCommitPage, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </DockPanel>
</Window>
