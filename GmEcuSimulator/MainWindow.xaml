<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GmEcuSimulator.Converters"
        xmlns:views="clr-namespace:GmEcuSimulator.Views"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:glitch="clr-namespace:Common.Glitch;assembly=EcuSim.Common"
        xmlns:common="clr-namespace:Common;assembly=EcuSim.Common"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="GmEcuSimulator.MainWindow"
        x:Name="EcuSimMainWindow"
        Title="{Binding WindowTitle, FallbackValue=GM ECU Simulator}"
        Icon="/Resources/app.ico"
        Height="900" Width="1130"
        MinHeight="810" MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter  x:Key="BoolToVis"/>
        <conv:BoolToGridLengthConverter  x:Key="BoolToGridLength"/>
        <conv:StatusToBrushConverter     x:Key="StatusToBrush"/>
        <conv:AppModeDisplayConverter    x:Key="AppModeDisplay"/>

        <!--
            Validation error template. Draws a 1px red border around the
            adorned input and surfaces the first error message as a tooltip.
            Applied to inspector textboxes via local Validation.ErrorTemplate.
            The error binding goes through AdornedElement so it picks up the
            validation message that INotifyDataErrorInfo raised.
        -->
        <ControlTemplate x:Key="ValidationErrorTemplate">
            <StackPanel>
                <AdornedElementPlaceholder x:Name="placeholder">
                    <Border BorderBrush="#E04848" BorderThickness="1"/>
                </AdornedElementPlaceholder>
            </StackPanel>
        </ControlTemplate>

        <!--
            Implicit TextBox augmentation: when the binding raises a
            validation error, show the red border template above and copy
            the first error message into the TextBox's ToolTip so hovering
            the field explains what's wrong. BasedOn keeps the theme-supplied
            base style intact (font, padding, brushes) so the only change is
            the added validation behaviour.
        -->
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <ObjectDataProvider x:Key="GlitchActions" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="glitch:GlitchAction"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Window.Style>
        <StaticResource ResourceKey="Window.AppShell"/>
    </Window.Style>

    <DockPanel LastChildFill="True">

        <!--
            TITLEBAR.
            Custom chrome. The first 36 pixels are draggable via
            WindowChrome.CaptionHeight; interactive zones (menu, status pill,
            window buttons) opt out via IsHitTestVisibleInChrome=True.
        -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource Chrome.GradientBrush}" Height="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Brand / title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                <Border Width="18" Height="18" CornerRadius="3"
                        Background="{DynamicResource Accent.PrimaryBrush}"
                        Margin="0,0,8,0">
                    <TextBlock Text="G" Foreground="White"
                               FontFamily="{StaticResource Font.SansDisplay}"
                               FontWeight="Bold" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding WindowTitle, FallbackValue=GM ECU Simulator}"
                           Style="{StaticResource Text.Body}"
                           Foreground="{DynamicResource Text.PrimaryBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Centre: status pills. Security state of the selected ECU
                 (left) + J2534 device registration state (right). -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Selected-ECU security pill: only renders when an ECU is
                     selected. Text comes from EcuViewModel.SecurityStatusText
                     which the main refresh tick updates 10x/sec, so it stays
                     in sync with $27 traffic without extra wiring. -->
                <Border CornerRadius="11"
                        Background="{DynamicResource Bg.SurfaceBrush}"
                        BorderBrush="{DynamicResource Border.SubtleBrush}"
                        BorderThickness="1"
                        Padding="10,3" Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Visibility="{Binding ShowsSecurityPill, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                        ToolTip="$27 SecurityAccess state of the selected ECU. Green = unlocked, amber = locked, red = lockout in effect. In DPS modes the pill stays visible before priming so the user knows where the indicator lives.">
                    <StackPanel Orientation="Horizontal" DataContext="{Binding SelectedEcu}">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                 Fill="{Binding SecurityStatusText, Converter={StaticResource StatusToBrush}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SecurityPillText, FallbackValue='No ECU primed', TargetNullValue='No ECU primed'}"
                                   Style="{StaticResource Text.Caption}"
                                   Foreground="{DynamicResource Text.PrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- J2534 status pill (live, accent-coloured dot + text) -->
                <Border CornerRadius="11"
                        Background="{DynamicResource Bg.SurfaceBrush}"
                        BorderBrush="{DynamicResource Border.SubtleBrush}"
                        BorderThickness="1"
                        Padding="10,3" Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="J2534 device registration state (HKLM\SOFTWARE\PassThruSupport.04.04\GmEcuSim)">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                 Fill="{Binding J2534Status, Converter={StaticResource StatusToBrush}}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding J2534Status}"
                                   Style="{StaticResource Text.Caption}"
                                   Foreground="{DynamicResource Text.PrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Right: window controls -->
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button x:Name="MinimizeBtn"
                        Style="{StaticResource Button.Chrome}"
                        Click="OnMinimizeClicked"
                        ToolTip="Minimize">
                    <Path Data="{StaticResource Icon.Minimize}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1.2"
                          Width="10" Height="10"/>
                </Button>
                <Button x:Name="MaximizeBtn"
                        Style="{StaticResource Button.Chrome}"
                        Click="OnMaximizeClicked"
                        ToolTip="Maximize">
                    <Path x:Name="MaxIcon"
                          Data="{StaticResource Icon.Maximize}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1.2"
                          Width="10" Height="10"/>
                </Button>
                <Button x:Name="CloseBtn"
                        Style="{StaticResource Button.ChromeClose}"
                        Click="OnCloseWindowClicked"
                        ToolTip="Close">
                    <Path Data="{StaticResource Icon.Close}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1.2"
                          Width="10" Height="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- MENU BAR + MODE SELECTOR.
             Menu items flow from the left; the top-level mode selector
             (DPS Write / DPS Read / Flash Tool Write / Flash Tool Read /
             ECU Simulator) is pinned to the right edge so the user can see
             at a glance which world they're in. Mode scopes single-vs-multi-
             ECU, per-mode persistence, and which tabs surface below. -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Bg.BaseBrush}"
                BorderBrush="{DynamicResource Border.SubtleBrush}"
                BorderThickness="0,0,0,1"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Menu Grid.Column="0" Padding="6,2" Background="Transparent">
                <MenuItem Header="_File">
                    <MenuItem Header="_New"      Command="{Binding NewCommand}"    InputGestureText="Ctrl+N"/>
                    <MenuItem Header="_Open…"    Command="{Binding OpenCommand}"   InputGestureText="Ctrl+O"/>
                    <Separator/>
                    <MenuItem Header="_Save"     Command="{Binding SaveCommand}"   InputGestureText="Ctrl+S"/>
                    <MenuItem Header="Save _As…" Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                    <Separator/>
                    <MenuItem Header="_Import…"  Command="{Binding ImportCommand}"/>
                    <MenuItem Header="_Export…"  Command="{Binding ExportCommand}"/>
                    <Separator Visibility="{Binding ShowsPrimeMenu, Converter={StaticResource BoolToVis}}"/>
                    <MenuItem Header="C_lear primed archive"    Command="{Binding ClearPrimeArchiveCommand}"
                              Visibility="{Binding ShowsPrimeMenu, Converter={StaticResource BoolToVis}}"
                              ToolTip="Forget the persisted prime path. Does not remove ECUs from the current bus."/>
                    <Separator/>
                    <MenuItem Header="E_xit"     Click="OnExitClicked"/>
                </MenuItem>
                <MenuItem Header="_J2534">
                    <MenuItem Header="_Register as J2534 device…"
                              Command="{Binding RegisterJ2534Command}"
                              ToolTip="Writes HKLM\SOFTWARE\PassThruSupport.04.04\GmEcuSim. Triggers a UAC prompt."/>
                    <MenuItem Header="_Unregister"
                              Command="{Binding UnregisterJ2534Command}"
                              ToolTip="Removes only the GmEcuSim entry; never touches other vendors. Triggers a UAC prompt."/>
                    <Separator/>
                    <MenuItem Header="_Show registered devices…"
                              Command="{Binding ShowRegisteredDevicesCommand}"
                              ToolTip="Lists every J2534 device on this machine in both registry views. Read-only - no UAC."/>
                    <Separator/>
                    <MenuItem Header="Reset _IPC pipe"
                              Command="{Binding ResetIpcPipeCommand}"
                              ToolTip="Stop and restart the \\.\pipe\GmEcuSim.PassThru server. Any connected host sees a broken pipe on its next call; new PassThruOpen calls succeed again. No UAC."/>
                </MenuItem>
                <MenuItem Header="_ECU">
                    <MenuItem Header="Reset _state"
                              Command="{Binding ResetStateCommand}"
                              ToolTip="Power-cycle every ECU: clears the programming session, security unlock, download buffer, and DPID schedules. Equivalent to $20 ReturnToNormalMode + full $27 re-lock applied to each ECU on the bus."/>
                    <Separator/>
                    <MenuItem Header="Drive HW _$3E keepalives"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding AllowPeriodicTesterPresent, Mode=TwoWay}"
                              ToolTip="When on, the simulator drives $3E TesterPresent on the host's behalf for any frame registered via PassThruStartPeriodicMsg. Off accepts the registration but skips the tick - delegating hosts have to keep their own P3C session alive."/>
                </MenuItem>
                <MenuItem Header="_Log">
                    <!-- Master gate. When unchecked, the four items below grey
                         out (their IsEnabled is bound to IsFileLoggingEnabled).
                         StaysOpenOnClick=True on every IsCheckable item keeps
                         the menu open so the user can flip several toggles at
                         once without re-opening the menu each time. -->
                    <MenuItem x:Name="LogToFileCheck"
                              Header="_Log to file"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding IsFileLoggingEnabled, Mode=TwoWay}"
                              ToolTip="Stream every bus + diagnostic line to %LOCALAPPDATA%\GmEcuSimulator\logs\bus logs\bus_*.csv on a dedicated background thread. Independent of the 'Log traffic' textbox gate - use when high-volume downloads make the textbox impractical."/>
                    <MenuItem Header="_Open folder…"
                              Click="OnOpenLogFolderClicked"
                              IsEnabled="{Binding IsFileLoggingEnabled}"
                              ToolTip="Open the log directory in Explorer."/>
                    <Separator/>
                    <MenuItem Header="Include _J2534 calls"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding LogIncludeJ2534Calls, Mode=TwoWay}"
                              IsEnabled="{Binding IsFileLoggingEnabled}"
                              ToolTip="When on, pipe-level J2534 calls (Open/Connect/StartMsgFilter/etc.) reach the file. The textbox / Download tab mirror is unaffected."/>
                    <MenuItem Header="Include _bus traffic"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding LogIncludeBusTraffic, Mode=TwoWay}"
                              IsEnabled="{Binding IsFileLoggingEnabled}"
                              ToolTip="When on, every CAN frame (Rx/Tx, including HOST FILTERED) reaches the file. The textbox is unaffected."/>
                    <MenuItem Header="_Append description tag"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding LogAppendDescriptionTag, Mode=TwoWay}"
                              IsEnabled="{Binding IsFileLoggingEnabled}"
                              ToolTip="Suffix every bus-frame line with a short human-readable tag (e.g. 'SecurityAccess - RequestSeed', 'ISO-TP FF (3110B) - TransferData @ 003FAFE0'). Tag is produced by Gmw3110Annotator from the raw bytes."/>
                    <MenuItem Header="_Collapse bulk transfers"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding LogCollapseBulkTransfers, Mode=TwoWay}"
                              IsEnabled="{Binding IsFileLoggingEnabled}"
                              ToolTip="Condense long ISO-TP transfers in the bus log: first 3 + last 3 CFs visible, middle replaced with a single '-- bulk transfer collapsed: N frames hidden --' marker. FC/TesterPresent noise inside the collapsed window is suppressed too. Threshold is 10 CFs - shorter transfers log normally."/>
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="_Setup window…"
                              Command="{Binding OpenSetupWindowCommand}"
                              InputGestureText="Ctrl+Shift+P"
                              ToolTip="Open the modeless setup window with PID parameters + waveform editor. The ECU selection there is independent of the main window's Selected ECU inspector."/>
                    <Separator/>
                    <MenuItem Header="_Theme" x:Name="ThemeMenu"
                              ToolTip="Switch the colour palette. Drop your own .xaml palette into %APPDATA%\GmEcuSimulator\Palettes\ to see it listed here."/>
                </MenuItem>
            </Menu>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Mode"
                               Style="{StaticResource Text.Caption}"
                               Foreground="{DynamicResource Text.SecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox Width="180"
                              ItemsSource="{Binding AvailableModes}"
                              SelectedItem="{Binding CurrentMode, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              ToolTip="Top-level mode. Switching clears the current ECU set; you'll be offered a save first when leaving a persistable mode.">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource AppModeDisplay}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <!-- Read-only modes (DpsRead / FlashToolRead) aren't
                             wired up yet; keep them visible-but-disabled so the
                             dropdown still telegraphs the planned scope. -->
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Static common:AppMode.DpsRead}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding}" Value="{x:Static common:AppMode.FlashToolRead}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STATUS BAR (bottom) -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Text.Caption}"
                           Foreground="{DynamicResource Text.PrimaryBrush}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding PrimeArchiveDisplay}" Style="{StaticResource Text.MonoDim}"
                               VerticalAlignment="Center" Margin="0,0,12,0"
                               ToolTip="Active Prime-From-Archive state. Set via the ECUs pane's Add button in DPS modes."/>
                    <TextBlock Text="Pipe" Style="{StaticResource Text.Caption}" Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="\\.\pipe\GmEcuSim.PassThru" Style="{StaticResource Text.MonoDim}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!--
            MAIN WORKSPACE.
            Two rows split by a horizontal GridSplitter. The "Maximize"
            checkbox in the bus-log tab collapses the editor row AND
            the outer margin / splitter so the tabbed workspace fills
            edge-to-edge.
        -->
        <Grid x:Name="MainContentGrid" Margin="14">
            <Grid.RowDefinitions>
                <!-- EditorRow MinHeight is the editor area's floor when the
                     user drags the horizontal splitter up. Floor budget:
                     card chrome + Selected-ECU title + ~2 form rows in the
                     WrapPanel ScrollViewer. Maximize toggles it to 0 from
                     code-behind so the row can fully collapse - the constant
                     in MainWindow.xaml.cs (EditorMinHeightNormal) restores
                     it and must stay in sync with this value. -->
                <RowDefinition x:Name="EditorRow" Height="*" MinHeight="240"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="LogRow"    Height="320" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- TWO PANE EDITOR (Row 0).
                 PIDs + Waveform moved to the modeless SetupWindow (see View
                 menu). This row keeps the ECU list + Selected ECU inspector. -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" MinWidth="0"/>
                    <ColumnDefinition Width="*"   MinWidth="320"/>
                </Grid.ColumnDefinitions>

                <!-- ECU sidebar.
                     Grid layout with Header (Auto) + ListBox (Star) so the
                     ListBox absorbs all remaining vertical space and its
                     inner ScrollViewer kicks in when ECU count exceeds the
                     visible area. The Selected-ECU inspector lives below
                     the PID grid now (middle column), not here. -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header: title + Add/Remove. In DPS modes the Add
                             button routes through AddEcu -> PrimeFromArchive
                             (see MainViewModel.AddEcu); CanAddEcu enforces the
                             single-ECU limit, so Add disables once one exists. -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ECUs" Style="{StaticResource Text.SectionHeader}"
                                       Margin="0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Width="28" Height="22" Padding="0" Margin="0,0,8,0"
                                        Command="{Binding AddEcuCommand}"
                                        ToolTip="ECU Simulator: insert a blank ECU at the next free OBD-II ID. DPS modes: open the Prime wizard (only one primed ECU is allowed).">
                                    <!-- Plus glyph: 10x10 viewport, centred cross. -->
                                    <Path Data="M 0,5 L 10,5 M 5,0 L 5,10"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          StrokeThickness="1.4"
                                          Width="10" Height="10"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button Width="28" Height="22" Padding="0"
                                        Command="{Binding RemoveEcuCommand}"
                                        ToolTip="Remove the selected ECU from the bus.">
                                    <!-- Minus glyph: matching 10x10 viewport. -->
                                    <Path Data="M 0,5 L 10,5"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          StrokeThickness="1.4"
                                          Width="10" Height="10"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Scrollable ECU list -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Ecus}"
                                 SelectedItem="{Binding SelectedEcu}"
                                 DisplayMemberPath="Name"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0" av:ItemsSource="{av:SampleData ItemCount=5}"/>
                    </Grid>
                </Border>

                <!-- Selected-ECU inspector card. Sole occupant of column 1
                     now that PIDs + Waveform live in the modeless setup
                     window. WrapPanel inside the ScrollViewer lets each
                     field cell (fixed 280px) flow into multiple columns
                     when the column is wide and collapse to one when it
                     shrinks. Bin-related actions (Load Info From Bin /
                     Auto-populate DIDs) moved out to the top-level Bin
                     menu; the in-card $1A Identifiers grid was retired
                     with them. -->
                <Border Grid.Column="1" Style="{StaticResource Card}"
                        DataContext="{Binding SelectedEcu}"
                        MinHeight="240"
                        Visibility="{Binding ConverterParameter=NotNull, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                        <!-- Three-row Grid (header / form fields / live PID panel).
                             When the PID grid is visible (ECU Simulator / DPS modes)
                             both content rows are "*" so they share the available
                             pane space; the form row is capped by FormRowMaxHeight
                             to its natural content height (no empty band when
                             there is room) and the PID row's MinHeight floors it
                             at ~ header + 1 DataGrid row. At the pane's MinHeight
                             that floor forces the form row below its natural size
                             and the form ScrollViewer's auto vertical scrollbar
                             reveals the remaining fields - so the inspector shows
                             only one row of properties at the tightest pane size
                             but expands to full natural height when there is room.
                             When the PID grid is hidden (Flash Tool Write) the
                             second row collapses to Auto and the form row sizes
                             to content. ElementName binding to the Window is used
                             because RowDefinition isn't in the visual tree, so
                             RelativeSource AncestorType doesn't reach it. -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="{Binding DataContext.ShowsPidLiveGrid,
                                                                ElementName=EcuSimMainWindow,
                                                                Converter={StaticResource BoolToGridLength},
                                                                ConverterParameter=*|Auto}"
                                               MinHeight="{Binding DataContext.PidRowMinHeight,
                                                                   ElementName=EcuSimMainWindow}"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Selected ECU"
                                           Style="{StaticResource Text.Subtitle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           Style="{StaticResource Text.Caption}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>
                                <Button Grid.Column="2"
                                        Content="Configure PIDs..."
                                        Padding="10,4"
                                        Margin="0,0,8,0"
                                        Command="{Binding DataContext.ConfigurePidsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding DataContext.IsEcuSimulatorMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                                        ToolTip="Open the modeless ECU Setup window pointed at this ECU. Edit the PID table (address, name, size, scaling) and per-PID waveform (shape, amplitude, frequency, phase, duty) used to synthesise $22 responses and DPID streams."/>
                                <Button Grid.Column="3"
                                        Content="Edit prime..."
                                        Padding="10,4"
                                        Command="{Binding EditPrimeCommand}"
                                        Visibility="{Binding IsPrimed, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
                                        ToolTip="Re-open the DPS Prime Wizard with this ECU's prior selections pre-filled. Replaces the ECU atomically on Apply."/>
                            </Grid>

                                <!-- Live PID panel. Shows the ECU's configured PIDs with their
                                     current waveform-sampled value. Read-only - editing happens
                                     in the Configure PIDs... dialog. LiveValue updates come from
                                     the MainWindow refresh timer (10 Hz). Sits in Row 2 of the
                                     enclosing Grid and takes the * row so it expands upward to
                                     fill the gap left under the form fields. The DataGrid inside
                                     scrolls internally if rows exceed the visible area. Hidden in
                                     Flash Tool Write mode - see MainViewModel.ShowsPidLiveGrid. -->
                                <Border Grid.Row="2"
                                        Margin="0,8,0,0"
                                        Padding="8"
                                        CornerRadius="4"
                                        BorderBrush="{DynamicResource Border.SubtleBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource Chrome.BgBrush}"
                                        Visibility="{Binding DataContext.ShowsPidLiveGrid, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                    <DockPanel LastChildFill="True">
                                        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="PIDs"
                                                       Style="{StaticResource Text.Subtitle}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Pids.Count, StringFormat=\{0\} configured}"
                                                       Style="{StaticResource Text.Caption}"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0,0,0"/>
                                        </Grid>
                                        <DataGrid ItemsSource="{Binding Pids}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  RowHeaderWidth="0"
                                                  SelectionMode="Single"
                                                  FontSize="14"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Address"
                                                                    Binding="{Binding AddressHex}"
                                                                    Width="90">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Name"
                                                                    Binding="{Binding Name}"
                                                                    Width="*" MinWidth="100"/>
                                                <DataGridTextColumn Header="Unit"
                                                                    Binding="{Binding Unit}"
                                                                    Width="60"/>
                                                <DataGridTextColumn Header="Live"
                                                                    Binding="{Binding LiveValue}"
                                                                    Width="90">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
                                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </Border>

                                <ScrollViewer Grid.Row="1"
                                              MaxHeight="{Binding DataContext.FormRowMaxHeight,
                                                                  ElementName=EcuSimMainWindow}"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <WrapPanel Orientation="Horizontal">
                                    <WrapPanel.Resources>
                                        <!-- Each form cell is a fixed-width Grid so the WrapPanel
                                             can lay out 2 columns when room permits, 1 when narrow.
                                             280px cell + 12px right gap = ~292px stride; two cells
                                             fit once the middle column exceeds ~600px. -->
                                        <Style x:Key="FormCell" TargetType="Grid">
                                            <Setter Property="Width" Value="280"/>
                                            <Setter Property="Margin" Value="0,0,12,4"/>
                                        </Style>
                                    </WrapPanel.Resources>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Name"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Req CAN"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding PhysicalRequestCanIdHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="USDT resp"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding UsdtResponseCanIdHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="UUDT resp"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding UudtResponseCanIdHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}"
                                          Visibility="{Binding DataContext.ShowsProgrammingFields, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="FC.BS"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding FlowControlBlockSizeHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 ToolTip="ISO 15765-2 FlowControl BlockSize (FC.BS). When this ECU receives a First Frame, it replies with FC = 30 BS 00. BS tells the tester how many Consecutive Frames to send before waiting for another FC: 0 = send all CFs in one burst (most permissive, works with most hosts); 1 = send 1 CF then wait for another FC, etc. Set BS=1 for the 6Speed.T43 tester - it sniffs the FC tail for the pattern '01' to recognise a T43 TCM and won't start the kernel upload otherwise."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}"
                                          Visibility="{Binding DataContext.ShowsProgrammingFields, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Diag addr"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding DiagnosticAddressHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 MaxLength="4"
                                                 ToolTip="GMW3110 8-bit diagnostic address. For SPS type C this is the byte that derives SPS_PrimeReq ($000|addr) and SPS_PrimeRsp ($300|addr). e.g. $11 -> req $011, resp $311. Informational for type A/B (their CAN IDs are explicit)."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}"
                                          Visibility="{Binding DataContext.ShowsSecurityModuleField, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Sec module"/>
                                        <ComboBox Grid.Column="1" Margin="0,2"
                                                  ItemsSource="{Binding AvailableSecurityModuleIds}"
                                                  SelectedItem="{Binding SelectedSecurityModuleId}"
                                                  FontFamily="{StaticResource Font.Mono}"
                                                  Height="40"
                                                  ToolTip="Seed/key algorithm for this ECU. (none) makes $27 return NRC $11. Runtime state (lock status, attempts, pending seed) lives on the Security tab."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}"
                                          Visibility="{Binding DataContext.ShowsSecurityModuleReadOnly, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Sec module"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding SelectedSecurityModuleId, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 ToolTip="Seed/key algorithm picked for this primed ECU. In DPS modes the Prime Wizard owns this choice - re-open the wizard (Edit primed) to change it."/>
                                    </Grid>

                                </WrapPanel>
                                </ScrollViewer>
                        </Grid>
                    </Border>
            </Grid>

            <!-- Horizontal splitter (Row 1) -->
            <GridSplitter x:Name="EditorSplitter" Grid.Row="1" Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Margin="0,6"
                          Background="Transparent">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="{x:Type GridSplitter}">
                        <Border Background="Transparent">
                            <Rectangle Height="1" Fill="{DynamicResource Border.SubtleBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Stretch"
                                       SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- TABBED WORKSPACE (Row 2) -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Bg.SurfaceBrush}"
                    BorderBrush="{DynamicResource Border.SubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <TabControl x:Name="BusLogTabControl" Margin="0">
                    <!-- Bus log tab -->
                    <TabItem Header="Bus log">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="LogTrafficCheck"
                                              Content="Log traffic"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsLoggingEnabled, Mode=TwoWay}"
                                              ToolTip="Master gate for the bus log AND the Download tab's mirror. Off by default - at $AA Fast 25Hz the bus frames alone can flood the textbox quickly."/>
                                    <Button Content="Clear" Click="OnClearLogClicked"
                                            Margin="16,0,0,0"/>
                                    <Rectangle Width="1" Margin="12,4" Fill="{DynamicResource Border.SubtleBrush}"/>
                                    <!-- File-log status only. The Log-to-file toggle and Open-folder
                                         button moved to the Log menu (top-level) so all file-log
                                         controls live in one place. The live status counter stays
                                         here so the user can see byte/line totals at a glance. -->
                                    <TextBlock Text="{Binding FileLogStatus, FallbackValue=Not logging}"
                                               VerticalAlignment="Center"
                                               FontFamily="{StaticResource Font.Mono}"
                                               Foreground="{DynamicResource Text.SecondaryBrush}"
                                               ToolTip="File-log status. Toggle 'Log to file' under the Log menu to start/stop the sink."/>
                                    <Rectangle Width="1" Margin="12,4" Fill="{DynamicResource Border.SubtleBrush}"/>
                                    <CheckBox x:Name="MaximizeBusLogCheck"
                                              Content="Maximize"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsMaximized, Mode=TwoWay}"
                                              ToolTip="Collapse the ECU/PID editor and fill the window with the workspace tabs. Shared with the Download tab's Maximize toggle."/>
                                    <CheckBox x:Name="HideTesterPresentCheck"
                                              Content="Hide $3E"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding SuppressTesterPresentInWindow, Mode=TwoWay}"
                                              ToolTip="Hide TesterPresent keepalives ($3E requests and $7E positive responses) from this log window only. The file-log capture is not affected."/>
                                </StackPanel>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="LogBoxColumn"     Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition x:Name="IpcLogBoxColumn"  Width="*"/>
                                </Grid.ColumnDefinitions>

                                <DockPanel Grid.Column="0">
                                    <Border DockPanel.Dock="Top"
                                            Background="{DynamicResource Bg.ElevatedBrush}"
                                            BorderBrush="{DynamicResource Border.SubtleBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,5">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6"
                                                     Fill="{DynamicResource Accent.PrimaryBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="CAN frames"
                                                       Style="{StaticResource Text.Caption}"
                                                       Foreground="{DynamicResource Text.PrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="Tx / Rx"
                                                       Style="{StaticResource Text.Caption}"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBox x:Name="LogBox"
                                             Style="{StaticResource TextBox.Log}"
                                             IsReadOnly="True"
                                             TextWrapping="NoWrap"/>
                                </DockPanel>

                                <GridSplitter x:Name="BusLogSplitter"
                                              Grid.Column="1" Width="6"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              Background="Transparent"
                                              MouseDoubleClick="OnBusLogSplitterDoubleClick"
                                              ToolTip="Drag to resize the CAN frames / J2534 calls panes. Double-click to reset to a 50/50 split.">
                                    <GridSplitter.Template>
                                        <ControlTemplate TargetType="{x:Type GridSplitter}">
                                            <Border Background="Transparent">
                                                <Rectangle Width="1" Fill="{DynamicResource Border.SubtleBrush}"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </GridSplitter.Template>
                                </GridSplitter>

                                <DockPanel Grid.Column="2">
                                    <Border DockPanel.Dock="Top"
                                            Background="{DynamicResource Bg.ElevatedBrush}"
                                            BorderBrush="{DynamicResource Border.SubtleBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,5">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6"
                                                     Fill="{DynamicResource Status.SuccessBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="J2534 calls"
                                                       Style="{StaticResource Text.Caption}"
                                                       Foreground="{DynamicResource Text.PrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="control plane"
                                                       Style="{StaticResource Text.Caption}"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBox x:Name="IpcLogBox"
                                             Style="{StaticResource TextBox.Log}"
                                             IsReadOnly="True"
                                             TextWrapping="NoWrap"/>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </TabItem>
<!-- (Download tab removed) -->

                    <!-- Bin Replay tab - ECU Simulator mode only -->
                    <TabItem Header="Bin Replay"
                             Visibility="{Binding ShowsBinReplayTab, Converter={StaticResource BoolToVis}}">
                        <views:BinReplayView DataContext="{Binding BinReplay}"/>
                    </TabItem>

                    <!-- (Security tab removed - reset moved to ECU > Reset state) -->

                    <!-- Glitch settings tab - ECU Simulator mode only -->
                    <TabItem Header="Glitch settings"
                             Visibility="{Binding ShowsGlitchTab, Converter={StaticResource BoolToVis}}">
                        <DockPanel DataContext="{Binding SelectedEcu}" LastChildFill="True">
                            <Border DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ECU"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name, FallbackValue=(none selected)}"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Rectangle Width="1" Margin="16,3" Fill="{DynamicResource Border.SubtleBrush}"/>
                                    <CheckBox Content="Enable glitch injection"
                                              IsChecked="{Binding Glitch.Enabled}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="prep - not yet wired into bus logic"
                                               Style="{StaticResource Text.Hint}"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>

                                <DataGrid Grid.Column="0"
                                          ItemsSource="{Binding Glitch.Services}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          BorderThickness="0,0,1,0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Service"
                                                            Binding="{Binding ServiceLabel}"
                                                            IsReadOnly="True" Width="*"/>
                                        <DataGridTextColumn Header="Probability %"
                                                            Binding="{Binding ProbabilityPercent, UpdateSourceTrigger=LostFocus}"
                                                            Width="120"/>
                                        <DataGridTemplateColumn Header="Action" Width="180">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Style="{StaticResource ComboBox.Cell}"
                                                              ItemsSource="{Binding Source={StaticResource GlitchActions}}"
                                                              SelectedItem="{Binding Action, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Column="1" Padding="14,12">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="NRC pool"
                                                   Style="{StaticResource Text.Subtitle}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="When EmitNrc fires, an NRC is randomly chosen from the ticked entries."
                                                   Style="{StaticResource Text.Hint}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,10"/>
                                        <StackPanel>
                                            <CheckBox Content="$11 serviceNotSupported"     IsChecked="{Binding Glitch.IncludeNrc11}" Margin="0,4"/>
                                            <CheckBox Content="$12 subFunctionNotSupported" IsChecked="{Binding Glitch.IncludeNrc12}" Margin="0,4"/>
                                            <CheckBox Content="$22 conditionsNotCorrect"    IsChecked="{Binding Glitch.IncludeNrc22}" Margin="0,4"/>
                                            <CheckBox Content="$31 requestOutOfRange"       IsChecked="{Binding Glitch.IncludeNrc31}" Margin="0,4"/>
                                            <CheckBox Content="$33 securityAccessDenied"    IsChecked="{Binding Glitch.IncludeNrc33}" Margin="0,4"/>
                                            <CheckBox Content="$78 busyResponsePending"     IsChecked="{Binding Glitch.IncludeNrc78}" Margin="0,4"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </DockPanel>
                    </TabItem>

                    <!-- Captures tab. Captures are written unconditionally;
                         this tab is a browser/launcher for the files.
                         Service36Handler anchors on the first $36 address so
                         real-DPS absolute-address sessions work without any
                         toggle. -->
                    <TabItem Header="Captures"
                             Visibility="{Binding ShowsCaptureTab, Converter={StaticResource BoolToVis}}">
                        <DockPanel DataContext="{Binding Capture}" LastChildFill="True">
                            <Border DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Open folder"
                                            Command="{Binding OpenFolderCommand}"
                                            Style="{StaticResource Button.Ghost}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Refresh"
                                            Command="{Binding RefreshCommand}"
                                            Style="{StaticResource Button.Ghost}"/>
                                </StackPanel>
                            </Border>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="18,12,18,6">
                                    <StackPanel>
                                        <TextBlock Text="CAPTURE DIRECTORY"
                                                   Style="{StaticResource Text.SectionHeader}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding CaptureDirectory}"
                                                   Style="{StaticResource Text.MonoDim}"
                                                   TextWrapping="NoWrap"
                                                   Margin="0,0,0,12"/>
                                        <TextBlock Text="CAPTURED FILES"
                                                   Style="{StaticResource Text.SectionHeader}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Each row is one programming session (a $34/$36 sequence ending in $20 ReturnToNormalMode or a P3C timeout). Filename embeds ECU name, UTC timestamp, base $36 address, and byte count."
                                                   Style="{StaticResource Text.Hint}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6"/>
                                    </StackPanel>
                                </Border>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Captures}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          Margin="14,0,14,12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="File"     Binding="{Binding FileName}" Width="*"/>
                                        <DataGridTextColumn Header="Size"     Binding="{Binding SizeText}" Width="100"/>
                                        <DataGridTextColumn Header="Modified" Binding="{Binding Modified, StringFormat=g}" Width="180"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>
