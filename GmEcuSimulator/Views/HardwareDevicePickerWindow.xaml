<Window x:Class="GmEcuSimulator.Views.HardwareDevicePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select CAN hardware"
        Height="440" Width="580"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontSize="14"
        Style="{StaticResource Window.Dialog}">

    <DockPanel LastChildFill="True">

        <!-- Custom titlebar -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource Chrome.GradientBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Select CAN hardware"
                       Style="{StaticResource Text.Body}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"/>
            <Button Grid.Column="1"
                    Style="{StaticResource Button.ChromeClose}"
                    Width="46" Height="32"
                    Click="OnCancelClicked"
                    ToolTip="Cancel">
                <Path Data="{StaticResource Icon.Close}"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.2"
                      Width="10" Height="10"/>
            </Button>
        </Grid>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource Chrome.BgBrush}"
                BorderBrush="{DynamicResource Border.SubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Button Content="Refresh" MinWidth="90" HorizontalAlignment="Left" Click="OnRefreshClicked"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" IsCancel="True" MinWidth="90" Click="OnCancelClicked"/>
                    <Button Content="Connect" IsDefault="True" MinWidth="110" Margin="10,0,0,0" Click="OnOkClicked"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Explanation -->
        <Border DockPanel.Dock="Top" Padding="14,12,14,8">
            <StackPanel>
                <TextBlock Text="Choose the physical CAN adapter that bridges the simulator to a real bus."
                           Style="{StaticResource Text.Subtitle}" TextWrapping="Wrap"/>
                <TextBlock Text="IXXAT USB-to-CAN needs its VCI driver installed; OBDX Pro lists each USB serial port plus the WiFi SoftAP. The bus opens at the GM rate (500 kbit/s, 11-bit)."
                           Style="{StaticResource Text.Caption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                <TextBlock x:Name="StatusText" Style="{StaticResource Text.Caption}"
                           Foreground="{DynamicResource Accent.PrimaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Device list -->
        <Border Margin="14,0,14,12" CornerRadius="4"
                BorderBrush="{DynamicResource Border.SubtleBrush}" BorderThickness="1">
            <ListBox x:Name="DeviceList" Margin="4" BorderThickness="0"
                     Background="Transparent"
                     MouseDoubleClick="OnOkClicked">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Adapter}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Description}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Detail}"
                                       Foreground="{DynamicResource Text.SecondaryBrush}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</Window>
